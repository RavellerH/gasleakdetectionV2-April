datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String   @default("admin")
  ruId      String   @default("ALL")
  role      String   @default("ADMIN") 
  devices   Device[] @relation("RegisteredBy")
  createdAt DateTime @default(now())
}

model Device {
  id            String   @id @default(cuid())
  macAddress    String   @unique
  name          String   // User-friendly device name
  deviceType    String   // SENSOR, ROUTING_NODE, CLUSTER_HEAD, GATEWAY
  ruId          String
  location      String
  batteryStats  String
  networkStats  String   // Will now store { rssiMesh, rssiStar, role, parentMac }
  healthScore   Int      @default(100)
  status        String   @default("ONLINE")
  registeredBy  String
  isDummy       Boolean  @default(false)

  // Hardware telemetry (PertaminaGLD integration)
  batteryMv     Int?
  lastSeenAt    DateTime?
  clusterId     Int?      // which Cluster Head this GLD reports through
  rssi          Int?
  snr           Float?

  // Commissioning mode (memory/commissioning_mode.md)
  commissioningStatus String   @default("DISCOVERED") // DISCOVERED | COMMISSIONING | ACTIVE
  discoveredAt        DateTime @default(now())
  commissionedAt       DateTime?
  commissionedBy        String?

  parentId      String?  // For Star Topology tracking
  parent        Device?  @relation("Topology", fields: [parentId], references: [id])
  children      Device[] @relation("Topology")

  readings      GasReading[]
  registeredByUser User? @relation("RegisteredBy", fields: [registeredBy], references: [id])
  registeredAt  DateTime @default(now())

  @@index([ruId, status])
  @@index([ruId, commissioningStatus])
}

model GasReading {
  id            String   @id @default(cuid())
  deviceId      String
  confidence    Float                    // AI confidence score 0.0–1.0 (wire protocol's 0-100 is converted at the MQTT ingestion boundary)
  aiClass       Int      @default(0)    // 0=normal, 1–6=gas type (PertaminaGLD gasClass)
  riskLevel     String   @default("LOW") // "LOW" | "MIDDLE" | "HIGH"
  powerMode     String?                  // "BATTERY" | "EXTERNAL" — from decoded externalPower flag
  isDummy       Boolean  @default(false)
  timestamp     DateTime @default(now())
  device        Device   @relation(fields: [deviceId], references: [id])

  @@index([deviceId, timestamp])
}

model SystemSettings {
  id                Int     @id @default(1)
  warningThreshold  Float   @default(0.70)  // MIDDLE risk: confidence >= this
  criticalThreshold Float   @default(0.80)  // HIGH risk:   confidence >= this
  refreshInterval   Int     @default(10)
  updatedAt         DateTime @updatedAt

  // Site setup (memory/commissioning_mode.md §4) — first-installation wizard, per-RU
  siteSetupComplete Boolean @default(false)
  ruName            String?
  ruLat             Float?
  ruLng             Float?
  mqttBrokerHost    String?
  mqttBrokerPort    Int?    @default(1884)
  aesKeyId          Int?    // record only — raw key material lives in Node-RED's .env, never in this DB
}

model EventLog {
  id             String    @id @default(cuid())
  type           String
  severity       String    @default("INFO")
  deviceId       String?
  ruId           String?
  operatorId     String?
  operatorEmail  String?
  message        String
  details        String?
  acknowledged   Boolean   @default(false)
  acknowledgedBy String?
  acknowledgedAt DateTime?
  ackNote        String?
  timestamp      DateTime  @default(now())

  @@index([timestamp])
  @@index([acknowledged])
}

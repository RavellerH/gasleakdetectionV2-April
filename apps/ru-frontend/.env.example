NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

# Which Refinery Unit this deployment is locked to. One instance of this app per RU.
NEXT_PUBLIC_RU_ID=RU3

# Map tiles: no token needed. The map streams OpenStreetMap tiles online by
# default. For offline / local tiles run `npm run tiles` once — it downloads
# the tiles for NEXT_PUBLIC_RU_ID into public/tiles and the map switches to
# them automatically.

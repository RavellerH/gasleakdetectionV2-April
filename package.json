{
  "name": "gas-leak-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Gas Leak Detector multi-RU monitoring platform - monorepo (backend + frontend) based on Gas-Leak-Design-v2.1.md",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev:backend": "cd apps/backend && npm run start:dev",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "dev": "npm-run-all -p dev:backend dev:frontend"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "axios": "^1.14.0"
  }
}

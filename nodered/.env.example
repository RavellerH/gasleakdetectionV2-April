# Per-RU Node-RED bridge config. Copy to .env and fill in real values.
# NEVER commit a real .env (already in .gitignore) — see memory/commissioning_mode.md §6
# for how keys get assigned to an RU during site setup.

# Embedded Aedes broker (started in-process by settings.js)
MQTT_HOST=127.0.0.1
MQTT_PORT=1884
MQTT_USER=
MQTT_PASS=

# AES-128-GCM key for this RU. keyId must match the byte the GLD firmware
# embeds in the encrypted payload (see memory/pertamina_gld_protocol.md).
# GLD_AES128_KEY_HEX must be exactly 32 hex chars (16 bytes).
GLD_KEY_ID=1
GLD_AES128_KEY_HEX=

# Node-RED admin UI port (separate from the MQTT broker port above)
NODE_RED_PORT=1880
